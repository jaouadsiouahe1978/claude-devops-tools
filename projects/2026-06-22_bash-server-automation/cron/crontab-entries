# Crontab entries pour Server Manager
# Ajouter ces lignes avec: sudo crontab -e

# Rapport quotidien à minuit
0 0 * * * /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/scripts/daily-report.sh >> /var/log/server-manager-cron.log 2>&1

# Health check toutes les 4 heures
0 */4 * * * /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/scripts/health-check.sh >> /var/log/server-manager-cron.log 2>&1

# Backup des configurations tous les dimanche à 2h du matin
0 2 * * 0 /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/scripts/backup-configs.sh backup >> /var/log/server-manager-cron.log 2>&1

# Nettoyage des vieux backups le 1er de chaque mois
0 3 1 * * /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/scripts/backup-configs.sh cleanup 30 >> /var/log/server-manager-cron.log 2>&1

# Rotation des logs du Server Manager tous les jours à 4h du matin
0 4 * * * source /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/config/server-config.sh && source /home/user/claude-devops-tools/projects/2026-06-22_bash-server-automation/modules/logging.sh && rotate_logs >> /var/log/server-manager-cron.log 2>&1
