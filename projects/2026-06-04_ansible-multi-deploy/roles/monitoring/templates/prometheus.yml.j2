global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    monitor: 'prometheus-{{ env }}'
    datacenter: '{{ datacenter }}'

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files:
  # - "first_rules.yml"
  # - "second_rules.yml"

scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Node Exporter - All servers
  - job_name: 'node-exporter'
    static_configs:
      - targets:
{% for host in groups['all'] %}
{% if hostvars[host].ansible_default_ipv4 is defined %}
          - '{{ hostvars[host].ansible_default_ipv4.address }}:9100'
{% endif %}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
      - source_labels: [__scheme__]
        target_label: scheme

  # Web servers monitoring
  - job_name: 'webservers'
    static_configs:
      - targets:
{% for host in groups['webservers'] %}
{% if hostvars[host].ansible_default_ipv4 is defined %}
          - '{{ hostvars[host].ansible_default_ipv4.address }}:9100'
{% endif %}
{% endfor %}
        labels:
          group: 'webservers'
    metrics_path: '/metrics'
    scrape_interval: 10s

  # Monitoring server
  - job_name: 'monitoring'
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
{% if hostvars[host].ansible_default_ipv4 is defined %}
          - '{{ hostvars[host].ansible_default_ipv4.address }}:9100'
{% endif %}
{% endfor %}
        labels:
          group: 'monitoring'
    scrape_interval: 10s
