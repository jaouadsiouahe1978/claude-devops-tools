[Unit]
Description=Node.js Application
After=network.target

[Service]
Type=simple
User={{ nodejs_user }}
WorkingDirectory={{ app_dir }}
Environment="PATH=/home/{{ nodejs_user }}/.nvm/versions/node/v{{ nodejs_version }}/bin"
Environment="NODE_ENV=production"
ExecStart=/home/{{ nodejs_user }}/.nvm/versions/node/v{{ nodejs_version }}/bin/pm2 start ecosystem.config.js --no-daemon
ExecReload=/bin/kill -s HUP $MAINPID
ExecStop=/home/{{ nodejs_user }}/.nvm/versions/node/v{{ nodejs_version }}/bin/pm2 stop ecosystem.config.js
Restart=always
RestartSec=10

# Security
NoNewPrivileges=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
