---
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    monitor: 'devops-stack'

scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Web servers Node Exporter
  - job_name: 'webservers'
    static_configs:
{% for host in groups.get('webservers', []) %}
      - targets: ['{{ hostvars[host].ansible_host }}:9100']
        labels:
          instance: '{{ host }}'
{% endfor %}

  # Database server Node Exporter
  - job_name: 'dbservers'
    static_configs:
{% for host in groups.get('dbservers', []) %}
      - targets: ['{{ hostvars[host].ansible_host }}:9100']
        labels:
          instance: '{{ host }}'
{% endfor %}

  # Application servers
  - job_name: 'applications'
    static_configs:
{% for host in groups.get('webservers', []) %}
      - targets: ['{{ hostvars[host].ansible_host }}:3000/metrics']
        labels:
          instance: '{{ host }}'
{% endfor %}

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files:
  - '/etc/prometheus/alert-rules.yml'
