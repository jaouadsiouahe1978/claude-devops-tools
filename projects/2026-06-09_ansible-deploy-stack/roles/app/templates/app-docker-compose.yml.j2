version: '3.8'

services:
  {{ app_name }}:
    build:
      context: /home/{{ ansible_user }}/{{ app_name }}
      dockerfile: Dockerfile
    image: {{ app_name }}:{{ app_version }}
    container_name: {{ app_name }}-app
    environment:
      - DB_HOST=postgres
      - DB_NAME={{ postgres_db }}
      - DB_USER={{ postgres_user }}
      - DB_PASSWORD={{ postgres_password }}
      - APP_PORT={{ app_port }}
      - FLASK_ENV={{ environment_type }}
    ports:
      - "{{ app_port }}:{{ app_port }}"
    depends_on:
      - postgres
    networks:
      - {{ docker_network_name }}
    restart: always
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ app_port }}/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  postgres:
    image: postgres:{{ postgres_version }}
    container_name: postgres-db
    environment:
      - POSTGRES_USER={{ postgres_user }}
      - POSTGRES_PASSWORD={{ postgres_password }}
      - POSTGRES_DB={{ postgres_db }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - {{ docker_network_name }}
    restart: always

networks:
  {{ docker_network_name }}:
    driver: bridge

volumes:
  postgres_data:
